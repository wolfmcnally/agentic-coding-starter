#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["pyyaml"]
# ///
"""role-models — read/write harness-aware per-role model/effort pins for /kickoff.

The four canonical roles (planner, reviewer, coder, critic) can each be pinned
to a model and optional reasoning effort, scoped by which harness is
orchestrating. The model code name implies its CLI. /kickoff reads the pins at
Step 0a and invokes each pinned role through the cross-harness CLI recipes;
unpinned roles run native. Orchestration and build gates always run on the
current session's model. Governed by policies/role-models.md.

  bin/role-models                              show pins + resolved view
  bin/role-models --show                       (same)
  bin/role-models [<harness>] <role>: <model>[@<effort>], ...
  bin/role-models --reset                      restore the shipped default
  bin/role-models --help                       this text

Harness sections:  default (base layer) | claude | codex
Roles:             planner reviewer coder critic
Models:            default | claude | codex | opus | fable | sol | terra | luna
Effort suffix:     @low | @medium | @high | @xhigh  (Codex or Claude)
                   @max                                (Claude only)
  default        native — the orchestrator's own session model (no CLI)
  claude         claude CLI, its configured default model (no --model)
  codex          codex CLI, its configured default model (no -m)
  opus | fable   claude --model opus|fable
  sol            codex -m gpt-5.6-sol
  terra          codex -m gpt-5.6-terra
  luna           codex -m gpt-5.6-luna

Append an effort when a role needs an explicit reasoning level:
  bin/role-models claude reviewer: sol@medium, critic: terra@low
  bin/role-models codex reviewer: opus@high, critic: fable@max

Resolution for a role R under orchestrating harness H:
  config[H][R]  if set, else  config['default'][R]  if set, else  default (native)

Set grammar: an optional leading harness token (default/claude/codex) selects the
section; omitted, pins land in the `default` section. Example:
  bin/role-models claude reviewer: codex, critic: codex
Unknown harness, role, model, effort, or invalid combination is rejected
non-zero and the file is left unchanged.
"""

import subprocess
import sys

import yaml

HARNESSES = ["default", "claude", "codex"]
ROLES = ["planner", "reviewer", "coder", "critic"]
MODELS = ["default", "claude", "codex", "opus", "fable", "sol", "terra", "luna"]
CODEX_MODELS = {
    "codex": None,
    "sol": "gpt-5.6-sol",
    "terra": "gpt-5.6-terra",
    "luna": "gpt-5.6-luna",
}
CLAUDE_MODELS = {
    "claude": None,
    "opus": "opus",
    "fable": "fable",
}
CODEX_EFFORTS = ["low", "medium", "high", "xhigh"]
CLAUDE_EFFORTS = ["low", "medium", "high", "xhigh", "max"]
CONFIG = "role-models.yaml"

# The shipped default reproduces cross-vendor review out of the box: whichever
# harness orchestrates, the reviewer and critic run in the *other* one.
SHIPPED_DEFAULT: dict[str, dict[str, str]] = {
    "default": {"planner": "default", "reviewer": "default", "coder": "default", "critic": "default"},
    "claude": {"reviewer": "codex", "critic": "codex"},
    "codex": {"reviewer": "opus", "critic": "opus"},
}

HEADER = """\
# role-models.yaml — per-role model/effort pins for /kickoff.
#
# Managed by bin/role-models; set via the /roles skill. Governed by
# policies/role-models.md. This file is a two-level YAML mapping:
#
#   <harness>:            # which harness is ORCHESTRATING /kickoff
#     <role>: <model>[@<effort>]  # model code name implies its CLI
#
# Harness sections:  default (base layer, applies under every harness)
#                    claude  (overrides when Claude Code orchestrates)
#                    codex   (overrides when Codex orchestrates)
# Roles:             planner  reviewer  coder  critic
# Models:            default | claude | codex | opus | fable | sol | terra | luna
# Effort suffix:     @low | @medium | @high | @xhigh  (Codex or Claude)
#                    @max                                (Claude only)
#   default        native — the orchestrator's own session model (no CLI)
#   claude         claude CLI, its configured default model (no --model)
#   codex          codex CLI, its configured default model (no -m)
#   opus | fable   claude --model opus|fable
#   sol            codex -m gpt-5.6-sol
#   terra          codex -m gpt-5.6-terra
#   luna           codex -m gpt-5.6-luna
# Append an effort when needed: sol@medium, terra@low, opus@high, fable@max.
#
# Resolution for role R under orchestrating harness H:
#   H's section, else the default section, else native.
# So the block below routes reviewer+critic to the *other* harness by default
# (cross-vendor review), and leaves planner+coder native.
"""


def die(msg: str) -> "None":
    sys.stderr.write(f"role-models: {msg}\n")
    raise SystemExit(1)


def repo_root() -> str:
    return subprocess.run(
        ["git", "rev-parse", "--show-toplevel"],
        capture_output=True, text=True, check=True,
    ).stdout.strip()


def parse_pin(pin: str) -> tuple[str, str | None]:
    """Return (model, effort), rejecting values outside the closed grammar."""
    model, separator, effort = str(pin).lower().partition("@")
    if model not in MODELS:
        die(f"unknown model '{model}' (models: {' '.join(MODELS)})")
    if not separator:
        return model, None
    if not effort or "@" in effort:
        die(f"invalid model/effort pin '{pin}' (expected model@effort)")
    efforts = supported_efforts(model)
    if not efforts:
        die(f"reasoning effort cannot be overridden for '{model}'")
    if effort not in efforts:
        die(f"unknown reasoning effort '{effort}' for '{model}' (efforts: {' '.join(efforts)})")
    return model, effort


def supported_efforts(model: str) -> list[str]:
    if model in CODEX_MODELS:
        return CODEX_EFFORTS
    if model in CLAUDE_MODELS:
        return CLAUDE_EFFORTS
    return []


def valid_pin(pin: object) -> bool:
    raw = str(pin).lower()
    model, separator, effort = raw.partition("@")
    if model not in MODELS:
        return False
    if not separator:
        return True
    return bool(effort and "@" not in effort and effort in supported_efforts(model))


def load() -> dict[str, dict[str, str]]:
    """Load the config leniently, keeping only known harness/role/model keys."""
    try:
        with open(CONFIG) as fh:
            raw = yaml.safe_load(fh) or {}
    except FileNotFoundError:
        return {}
    if not isinstance(raw, dict):
        die(f"{CONFIG} is not a YAML mapping")
    cfg: dict[str, dict[str, str]] = {}
    for harness, roles in raw.items():
        if harness not in HARNESSES or not isinstance(roles, dict):
            sys.stderr.write(f"role-models: ignoring unknown section '{harness}' in {CONFIG}\n")
            continue
        for role, pin in roles.items():
            if role in ROLES and valid_pin(pin):
                cfg.setdefault(harness, {})[role] = str(pin).lower()
            else:
                sys.stderr.write(f"role-models: ignoring '{harness}.{role}: {pin}' in {CONFIG}\n")
    return cfg


def dump(cfg: dict[str, dict[str, str]]) -> None:
    """Write the config canonically: sections and roles in fixed order, with the header."""
    ordered = {
        h: {r: cfg[h][r] for r in ROLES if r in cfg[h]}
        for h in HARNESSES if cfg.get(h)
    }
    body = yaml.safe_dump(ordered, sort_keys=False, default_flow_style=False, indent=2)
    with open(CONFIG, "w") as fh:
        fh.write(HEADER + "\n" + body)


def detect_harness() -> str:
    import os
    return "claude" if os.environ.get("CLAUDECODE") == "1" else "codex"


def resolve(cfg: dict[str, dict[str, str]], harness: str) -> dict[str, str]:
    out = {}
    for role in ROLES:
        out[role] = cfg.get(harness, {}).get(role) or cfg.get("default", {}).get(role) or "default"
    return out


VENUE = {
    "default": "native (session model)",
    "claude": "claude CLI (default model)",
    "codex": "codex CLI (default model)",
    "opus": "claude --model opus",
    "fable": "claude --model fable",
}


def describe_pin(pin: str) -> str:
    model, effort = parse_pin(pin)
    codex_model = CODEX_MODELS.get(model)
    description = f"codex --model {codex_model}" if codex_model else VENUE[model]
    if effort:
        if model in CODEX_MODELS:
            description += f" -c 'model_reasoning_effort=\"{effort}\"'"
        else:
            description += f" --effort {effort}"
    return description


def show(cfg: dict[str, dict[str, str]]) -> None:
    if cfg:
        print("Configured pins (by orchestrating harness):")
        for h in HARNESSES:
            if cfg.get(h):
                print(f"  {h}:")
                for r in ROLES:
                    if r in cfg[h]:
                        print(f"    {r:<9} {cfg[h][r]}")
    else:
        print(f"(no {CONFIG} — every role runs native)")
    h = detect_harness()
    print(f"\nResolved for this harness ({h}):")
    for role, value in resolve(cfg, h).items():
        print(f"  {role:<9} {value:<16} → {describe_pin(value)}")


def set_pins(argv: list[str]) -> None:
    section = "default"
    if argv and ":" not in argv[0] and argv[0].lower() in HARNESSES:
        section = argv[0].lower()
        argv = argv[1:]
    raw = " ".join(argv)
    staged: list[tuple[str, str]] = []
    for pair in raw.split(","):
        if not pair.strip():
            continue
        if ":" not in pair:
            die(f"expected 'role: model[@effort]', got '{pair.strip()}'")
        role, pin = pair.split(":", 1)
        role = role.strip().lower()
        pin = pin.strip().lower()
        if role not in ROLES:
            die(f"unknown role '{role}' (roles: {' '.join(ROLES)})")
        parse_pin(pin)
        staged.append((role, pin))
    if not staged:
        die("no pins given (usage: role-models [<harness>] <role>: <model>[@<effort>], ...)")
    cfg = load()
    for role, pin in staged:
        cfg.setdefault(section, {})[role] = pin
    dump(cfg)
    show(load())


def main() -> None:
    args = sys.argv[1:]
    if args and args[0] in ("--help", "-h"):
        print(__doc__, end="")
        return
    import os
    os.chdir(repo_root())
    if not args or args[0] == "--show":
        show(load())
    elif args[0] == "--reset":
        dump(SHIPPED_DEFAULT)
        show(load())
    else:
        set_pins(args)


if __name__ == "__main__":
    main()
