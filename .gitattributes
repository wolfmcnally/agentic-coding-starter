# Normalize line endings on commit; check out platform-native by default.
* text=auto

# Files that must stay LF regardless of platform.
# bin/*.sh run under bash (Git Bash / WSL); a CRLF shebang breaks the interpreter.
*.sh text eol=lf

# Markdown, config, and source the methodology treats as canonical: keep LF
# so cross-harness mirrors and diffs stay byte-identical across platforms.
*.md text eol=lf
*.toml text eol=lf
*.py text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
